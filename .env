# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_EXTERNAL_PORT=8000

# Chroma
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_SSL=false
CHROMA_COLLECTION_NAME=documents
CHROMA_EXTERNAL_PORT=8001

# Default lightweight local run
EMBEDDER_PROVIDER=hash
GENERATOR_PROVIDER=simple
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
GENERATOR_MODEL_NAME=google/flan-t5-small

# External API provider setup
EXTERNAL_EMBEDDING_API_KEY=
EXTERNAL_EMBEDDING_BASE_URL=https://api.openai.com/v1
EXTERNAL_GENERATOR_API_KEY=
EXTERNAL_GENERATOR_BASE_URL=https://api.openai.com/v1

# Optional local model service profile
# Start with: docker compose --profile local-model up --build
# The current app can also run fully without this service by using
# EMBEDDER_PROVIDER=hash and GENERATOR_PROVIDER=simple, or by using the
# in-process local providers from the Python app itself.
LOCAL_MODEL_ENDPOINT=http://model:11434
LOCAL_MODEL_EXTERNAL_PORT=11434

# Example external-provider mode:
# EMBEDDER_PROVIDER=external
# EMBEDDING_MODEL_NAME=text-embedding-3-small
# GENERATOR_PROVIDER=external
# GENERATOR_MODEL_NAME=gpt-4o-mini

# Example optional local-provider mode:
# EMBEDDER_PROVIDER=local
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# GENERATOR_PROVIDER=local
# GENERATOR_MODEL_NAME=google/flan-t5-small
